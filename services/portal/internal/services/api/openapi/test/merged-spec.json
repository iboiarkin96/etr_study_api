          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/createCourse_CreateCourseRequest"
              },
              "examples": {
                "short_track": {
                  "$ref": "#/components/examples/createCourse_short_track"
                },
                "long_track": {
                  "$ref": "#/components/examples/createCourse_long_track"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created — the persisted course.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/createCourse_Course"
                },
                "examples": {
                  "short_track": {
                    "$ref": "#/components/examples/createCourse_short_track"
