                      "name": "Alice Example",
                      "email": "alice@example.com"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateUser",
        "summary": "Replace a user's editable fields.",
        "description": "Replaces the current user's `email` with the supplied\nvalue. Returns the updated user on success.\n\nIdempotent per `Idempotency-Key` (required header) — a repeated\nrequest with the same key within the idempotency window replays\nthe cached response.\n",
        "tags": [
          "User"
