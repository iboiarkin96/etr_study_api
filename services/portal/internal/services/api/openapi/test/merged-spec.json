    "/api/v1/courses/test": {
      "get": {
        "operationId": "getCourse",
        "summary": "Look up a course by name.",
        "description": "Returns the course whose `name` exactly matches the query parameter.\nCourse names are unique across the resource, so at most one course\nis returned.\n",
        "tags": [
          "All courses"
        ],
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "description": "Course name to look up. Match is exact and case-sensitive. Constrained to the same 1..80-char range.\n",
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 80
            },
            "example": "Introduction to Python"
          }
        ],
        "responses": {
          "200": {
            "description": "OK — the course with the matching name.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/getCourse_Course"
                },
                "examples": {
                  "default": {
                    "summary": "A course with a short beginner track",
                    "value": {
                      "name": "Introduction to Python",
                      "length": 10
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/users/test": {
      "get": {
        "operationId": "getUser",
        "summary": "Look up a user by email.",
        "description": "Returns the user whose email exactly matches the query parameter.\nEmail uniqueness is enforced across the User resource, so at most\none user is returned. Returns `404 Not Found` when no user matches.\n",
        "tags": [
          "User"
        ],
        "parameters": [
