# Service-local ignores. Cross-cutting patterns (node_modules, .vite,
# .eslintcache, *.tsbuildinfo, dist/) already live in the root .gitignore.
# Any Node artefact specific to this service goes here.

*storybook.log
storybook-static

# Playwright — keep baselines in git, ignore reports + transient outputs
playwright-report/
test-results/
blob-report/
playwright/.cache/
