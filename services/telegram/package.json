{
  "name": "@study-app/telegram",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Telegram Mini App client for the Study App daily loop (ETR).",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen-api": "openapi-typescript ../portal/public/reference/api/openapi.json -o src/shared/api/schema.d.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:visual": "playwright test --project=dark --project=light",
    "test:visual:update": "playwright test --project=dark --project=light --update-snapshots",
    "test:a11y": "playwright test --project=a11y"
  },
  "dependencies": {
    "@sentry/react": "^10.67.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.87.0",
    "@telegram-apps/sdk-react": "^3.1.0",
    "@telegram-apps/telegram-ui": "^2.1.0",
    "framer-motion": "^11.15.0",
    "i18next": "^24.2.3",
    "posthog-js": "^1.203.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^15.7.4",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@chromatic-com/storybook": "^5.2.1",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.1",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/react-vite": "^10.5.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/ui": "^4.1.10",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "eslint-plugin-storybook": "^10.5.2",
    "globals": "^15.14.0",
    "happy-dom": "^20.11.0",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.61.1",
    "storybook": "^10.5.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.0.7",
    "vitest": "^4.1.10"
  }
}
