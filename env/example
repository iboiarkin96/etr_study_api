# =============================================================================
# ETR Study App — environment template (per ADR 0010)
# =============================================================================
#
# This file is the CANONICAL TEMPLATE. Every environment variable the app or
# its Docker stack reads has a documented slot here — with the real value for
# public defaults and an empty slot for secrets.
#
# Two-layer policy (see ADR 0010 · «Where each key lives»)
# --------------------------------------------------------
#   env/{dev,qa,prod}   — committed. Public profile behavior.
#                          LOG_LEVEL, CORS_ALLOW_ORIGINS, rate limits,
#                          dev-only JWT_SECRET / API_AUTH_KEY defaults.
#                          REAL SECRETS NEVER GO HERE.
#
#   .env  (repo root)   — GIT-IGNORED. Private secrets + per-developer overrides.
#                          TELEGRAM_BOT_TOKEN, OPENROUTER_API_KEY,
#                          GRAFANA_ADMIN_PASSWORD, personal LOG_LEVEL, etc.
#
# The two files are LAYERED, not duplicated. A key never appears in both:
# public-slot values live in env/*, private-slot values live in .env.
#
# Getting started
# ---------------
#   cp env/example .env             # or: make env-init
#   # Then edit .env: paste real secrets under the SECRETS section,
#   # leave the public-behavior section alone.
#
# Load order — HOST (see app/core/config.py::_load_env_files)
# ----------------------------------------------------------
#   1. Root .env               (override=False; shell-exported values survive)
#   2. env/<APP_ENV>           (override=True; wins over .env for public keys)
#   3. optional ENV_FILE       (final override; deployment-specific paths)
#   4. _PARENT_WINS_KEYS       (small allowlist: DATABASE_URL, JWT_SECRET,
#                               TELEGRAM_BOT_TOKEN, rate-limit overrides —
#                               re-applied from shell after profile load so
#                               tests / load runs don't get clobbered)
#
# Load order — DOCKER (see docker-compose.yml `env_file:` blocks)
# ----------------------------------------------------------
#   1. env/<APP_ENV>           (public behavior — same file the host uses)
#   2. .env                    (secrets — REAL values injected into container)
#   3. compose `environment:`  (container-specific overrides, e.g.
#                               DATABASE_URL=postgres:5432, APP_HOST=0.0.0.0)
#
# APP_ENV must be one of: dev | qa | prod (aliases: local → dev, test → qa).
# NEVER set APP_ENV inside a profile file — it's the switch that PICKS the
# profile. Set it in the shell, docker-compose environment:, or deployment
# platform. Stricter rules apply in qa/prod (auth, metrics, CORS, log level,
# JWT secret strength — see get_settings()).
#
# Sections in this file
# ---------------------
#   Application bind / Database
#   Logging
#   CORS and API security (body size, rate limits, auth)
#   Load testing helpers (Makefile / tools.load_testing)
#   Metrics and readiness
#   Observability — host:port labels for scripts and docs (not all read by the app)
#   Docker Compose — Prometheus, Grafana, Blackbox (make observability-up)
#   Docker Compose — Elasticsearch, Kibana, Filebeat (make logging-up); use with LOG_FORMAT=json
#
# =============================================================================
#
# Optional — changelog LLM draft + scripts/llm_ping.py (not used by the API)
# -----------------------------------------------------------------------------
# OpenAI:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
#
# OpenRouter (default model if OPENAI_MODEL unset: openrouter/free — see OpenRouter docs):
# OPENROUTER_API_KEY=sk-or-v1-...
# # OPENAI_BASE_URL=https://openrouter.ai/api/v1   # implied when only OPENROUTER_API_KEY is set
# OPENAI_MODEL=deepseek/deepseek-chat
# OPENROUTER_HTTP_REFERER=http://127.0.0.1:3000
# OPENROUTER_APP_TITLE=study_app
#
# =============================================================================

# --- Application & database -------------------------------------------------

# Shown in OpenAPI metadata.
APP_NAME="ETR Study App API"

# Logical environment: dev | qa | prod
APP_ENV=dev

# HTTP server bind (Uvicorn).
APP_HOST=127.0.0.1
APP_PORT=8000

# Optional: extra file applied last (secrets, host-specific). Uncomment and set.
# Path: relative to project root or absolute.
# ENV_FILE=

# Database URL (ADR 0037). PostgreSQL 16 running in the compose stack as
# service `postgres`; from the api container the hostname is `postgres`, from the
# host machine it is `127.0.0.1`. psycopg3 is the driver.
#   Compose (api → postgres):  postgresql+psycopg://study_app:study_app@postgres:5432/study_app
#   Host (make run / pytest):  postgresql+psycopg://study_app:study_app@127.0.0.1:5432/study_app
DATABASE_URL=postgresql+psycopg://study_app:study_app@127.0.0.1:5432/study_app

# Bootstrap credentials for the compose `postgres` service (used only by the
# Postgres container's official entrypoint on first boot; the API reads
# DATABASE_URL above).
POSTGRES_USER=study_app
POSTGRES_PASSWORD=study_app
POSTGRES_DB=study_app
POSTGRES_PORT=5432

# --- Logging ---------------------------------------------------------------

LOG_DIR=logs
LOG_FILE_NAME=app.log
# Typical: DEBUG, INFO, WARNING, ERROR (prod forbids DEBUG).
LOG_LEVEL=INFO
# json (default if unset in app) = NDJSON with top-level request_id for Kibana/ES; text = human-readable lines.
LOG_FORMAT=json
# Stable service id in JSON logs (field "service"); keep short and constant across deploys.
LOG_SERVICE_NAME=study-app-api

# --- CORS (browser clients) ------------------------------------------------

# Comma-separated origins, methods, headers.
# Include http://127.0.0.1:8765 (and localhost) if you serve docs/ from that origin and call the API
# from the browser (e.g. FastAPI /docs Try it out). Static docs/public/reference/api/index.html
# (OpenAPI test) is browse-only and does not call the API.
# 5173 = Vite dev server (Telegram Mini App). Add your Cloudflare Tunnel origin
# here for on-device dev sessions.
CORS_ALLOW_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:8765,http://localhost:8765,http://127.0.0.1:5173,http://localhost:5173
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
# Idempotency-Key is required for browser preflight on write endpoints from Swagger UI.
CORS_ALLOW_HEADERS=Authorization,Content-Type,X-API-Key,Idempotency-Key,X-Request-Id
# Response headers readable by JS on cross-origin responses (Swagger on another port, SPAs).
CORS_EXPOSE_HEADERS=X-Request-Id,X-RateLimit-Limit,X-RateLimit-Remaining,Retry-After
CORS_ALLOW_CREDENTIALS=false

# --- API security & limits --------------------------------------------------

# Maximum JSON body size in bytes (request rejected if larger).
API_BODY_MAX_BYTES=1048576

# Sliding-window rate limit per client+path (see app middleware).
API_RATE_LIMIT_REQUESTS=60
API_RATE_LIMIT_WINDOW_SECONDS=60

# For local load-test servers (make run-loadtest-api / run-loadtest-api-serve) the
# Makefile exports very high limits unless you set API_RATE_LIMIT_REQUESTS_LOADTEST
# in the environment. Otherwise raise API_RATE_LIMIT_* here for load tests.

# Protected routes require this key in the API_AUTH_HEADER header.
# qa/prod refuse to boot with the default value.
API_AUTH_KEY=local-dev-key
API_AUTH_HEADER=X-API-Key

# URL prefix where auth + rate limiting apply (e.g. /api/v1).
API_PROTECTED_PREFIX=/api/v1

# --- Telegram bot (Mini App epic) ---
# Token from BotFather and the maintainer's chat id. Both are secrets — set real
# values in the root `.env`, never in committed env/* files. Empty = bot disabled.
# TELEGRAM_BOT_TOKEN also serves as the HMAC key when verifying initData at
# POST /api/v1/auth/telegram.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Maximum accepted age of the initData `auth_date` field (seconds). Payloads
# older than this are rejected as replay attempts. 86400 = 24 hours.
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400

# --- JWT auth (Mini App epic) ------------------------------------------------
# Signing key for the 24 h JWT issued at POST /api/v1/auth/telegram.
# qa/prod refuse to boot with the default value or with any value shorter than 32 bytes.
JWT_SECRET=local-dev-jwt-secret-32-bytes-min
JWT_TTL_SECONDS=86400

# --- Load testing (optional endpoints & runner defaults) --------------------

# When true, exposes GET /__loadtest/http500 for synthetic 5xx (local/traffic tests only).
LOADTEST_HTTP_500=false

# Defaults for tools/load_testing/run_with_local_api.sh when LOADTEST_TOTAL_REQUESTS
# and LOADTEST_DELAY_MS are not set (see Makefile run-loadtest-api).
LOADTEST_DEFAULT_TOTAL_REQUESTS=100
LOADTEST_DEFAULT_DELAY_MS=0

# --- Metrics & readiness (application) -------------------------------------

METRICS_ENABLED=true
METRICS_PATH=/metrics

# Max wait when checking DB during GET /ready.
READINESS_DB_TIMEOUT_MS=250

# Histogram bucket boundaries for Prometheus metrics (seconds, comma-separated).
METRICS_BUCKETS_HTTP=0.005,0.01,0.025,0.05,0.1,0.25,0.5,1,2.5,5
METRICS_BUCKETS_DB=0.001,0.0025,0.005,0.01,0.025,0.05,0.1,0.25

# --- Observability — labels for docs & helper scripts -----------------------
# These host/port pairs are used by README tables, observability-smoke, etc.
# They do not replace APP_HOST/APP_PORT for the API process.

OBS_API_HOST=127.0.0.1
OBS_API_PORT=8000
OBS_PROM_HOST=127.0.0.1
OBS_PROM_PORT=9090
OBS_GRAF_HOST=127.0.0.1
OBS_GRAF_PORT=3010
# Elasticsearch + Kibana (make logging-up / scripts/check_logging_links.py)
OBS_ES_HOST=127.0.0.1
OBS_ES_PORT=9200
OBS_KIB_HOST=127.0.0.1
OBS_KIB_PORT=5601

# --- Docker: Prometheus, Grafana, Blackbox (docker-compose.observability) ---

PROMETHEUS_PORT=9090
# 3010 not 3000/3001 — VS Code Helper on macOS commonly binds 3000-3009 on the
# IPv4 loopback, which causes browsers to hit VS Code (426 Upgrade Required)
# instead of the Grafana container that Docker binds on the same port via IPv6.
GRAFANA_PORT=3010
# Target the API from inside Docker (macOS/Windows Docker Desktop).
PROMETHEUS_SCRAPE_TARGET=host.docker.internal:8000

# URL Blackbox probes for readiness SLO; rendered into services/monitoring/prometheus/prometheus.yml
# by scripts/render_prometheus_config.py.
PROMETHEUS_READY_PROBE_URL=http://host.docker.internal:8000/ready

BLACKBOX_EXPORTER_PORT=9115

# Grafana first-login credentials (change in real deployments).
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- Docker: Elasticsearch + Kibana + Filebeat (docker-compose.logging.yml) ---
# Optional local log analytics. Set LOG_FORMAT=json so Filebeat can parse NDJSON lines from LOG_DIR.
# Allocate ~2 GiB RAM for ES+Kibana. Elasticsearch and Kibana are free to self-host for development
# (see docs/adr/0023-structured-logging-and-local-elasticsearch.html).

ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
