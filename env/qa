# Loaded after .env when APP_ENV=qa (includes automated tests)
LOG_LEVEL=INFO
# ADR 0037: PostgreSQL. Tests spin up their own testcontainer and override this at
# import time (tests/conftest.py); this line is the fallback for non-test qa flows.
DATABASE_URL=postgresql+psycopg://study_app:study_app@127.0.0.1:5432/study_app
# Both are secrets — set real values in the root `.env` (gitignored),
# never commit them here. Empty = bot disabled. TELEGRAM_BOT_TOKEN also serves
# as the HMAC key for verifying Telegram Mini App initData.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS=86400

# JWT signing key for POST /api/v1/auth/telegram. Must not be the default and
# must be at least 32 bytes; startup fails otherwise. Set the real value in
# the root `.env` (gitignored).
JWT_SECRET=
JWT_TTL_SECONDS=86400
