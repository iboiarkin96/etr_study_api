@startuml
title API run and optional Docker observability

top to bottom direction

rectangle "make run-project" as rproj

package "Host (venv)" {
  rectangle "make run" as run
  rectangle "make container-start" as cstart
}

package "Docker Compose" {
  rectangle "make observability-up" as obup
  rectangle "make observability-down" as obdown
  rectangle "make observability-smoke" as obsmoke
}

rproj -down-> obup : starts
rproj -down-> run : starts
obup .. run : optional\nalongside

@enduml
