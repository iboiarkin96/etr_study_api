@startuml
title Study App - Sequence: Create Note

autonumber
hide footbox
skinparam shadowing false
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 80
skinparam ParticipantPadding 16
skinparam BoxPadding 8
skinparam ArrowColor #334155

actor "Client App" as Client
boundary "HTTP API" as Api
control "ConspectusService" as Service
participant "SchedulePolicy" as Policy
database "Repo + DB" as RepoDb

Client -> Api: POST /conspectuses
activate Api
Api -> Api: validate payload

alt invalid payload
  Api --> Client: 422 Validation Error
  deactivate Api
else valid payload
  Api -> Service: create(user_id, payload)
  activate Service
  Service -> Policy: calculate slot and review date
  Policy --> Service: slot A, next_review_at
  Service -> RepoDb: insert note (transaction)
  RepoDb --> Service: created entity
  Service --> Api: response DTO
  deactivate Service
  Api --> Client: 201 Created
  deactivate Api
end

@enduml
