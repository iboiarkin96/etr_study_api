@startuml
title Study App - C4 L2 Container View

skinparam shadowing false
skinparam linetype polyline
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ArrowColor #334155
skinparam PackageBorderColor #94a3b8
skinparam ComponentBorderColor #64748b
skinparam ComponentBackgroundColor #f8fafc
skinparam DatabaseBorderColor #64748b
skinparam DatabaseBackgroundColor #f8fafc
left to right direction

actor "Client App" as Client

node "Study App Runtime" {
  [HTTP API\nFastAPI + Routers] as Http
  [Application\nServices + Schemas] as App
  [Persistence\nRepositories + ORM] as Persist
}

database "SQLite\nstudy_app.db" as Db
[Alembic CLI] as Mig

Client --> Http : HTTPS
Http --> App : use cases
App --> Persist : data access
Persist --> Db : SQL
Mig --> Db : schema migration

note bottom of App
  Layering: API -> Services -> Repositories -> DB
end note

@enduml
