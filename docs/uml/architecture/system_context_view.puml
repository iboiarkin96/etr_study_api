@startuml
title Study App - C4 L1 System Context

skinparam shadowing false
skinparam linetype polyline
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam defaultFontName Arial
skinparam defaultFontSize 12
skinparam ArrowColor #334155
skinparam PackageBorderColor #94a3b8
skinparam ComponentBorderColor #64748b
skinparam ComponentBackgroundColor #f8fafc
left to right direction

actor Learner
actor Mentor
actor Operator

rectangle "Study App API" as Api

package "Client Apps" {
  [Web] as Web
  [Mobile] as Mobile
  [Bot Adapter] as Bot
}

package "External Systems (planned)" {
  [Identity Provider] as Idp
  [Observability] as Obs
}

Learner --> Web
Learner --> Mobile
Mentor --> Web
Operator --> Bot

Web --> Api : HTTPS / JSON
Mobile --> Api : HTTPS / JSON
Bot --> Api : HTTPS / JSON

Api ..> Idp : auth integration
Api ..> Obs : metrics and logs

@enduml
