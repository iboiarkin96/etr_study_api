' Shared PlantUML skin (injected after @startuml by scripts/regenerate_docs.py for Kroki single-file render)
' Typography: Arial/Helvetica stack matches typical Linux server fonts (Kroki) — avoids Segoe-only drift.
skinparam shadowing false
skinparam linetype ortho
skinparam componentStyle rectangle
skinparam packageStyle rectangle
skinparam defaultFontName "Arial"
skinparam defaultFontSize 10
' Balance: tight enough to avoid huge gaps, loose enough to limit label/arrow overlap. Split diagrams if still crowded.
skinparam nodesep 20
skinparam ranksep 17
skinparam Padding 6
skinparam dpi 96
' Uniform export width for layout; SVG stays sharp at any zoom in the browser.
' Regenerate outputs after changing this value (``make docs-fix`` / ``regenerate_docs.py``).
scale 960 width
skinparam roundcorner 8
' Restrained palette: neutrals + one blue accent (application path); warm tint for persistence.
skinparam ArrowColor #64748B
skinparam ArrowThickness 1.1
skinparam ArrowFontSize 9
skinparam PackageBorderColor #CBD5E1
skinparam PackageBackgroundColor #F1F5F9
skinparam RectangleBorderColor #2563EB
skinparam RectangleBackgroundColor #F8FAFC
skinparam DatabaseBorderColor #C2410C
skinparam DatabaseBackgroundColor #FFF7ED
skinparam NodeBorderColor #64748B
skinparam NodeBackgroundColor #F8FAFC
skinparam ActorBorderColor #047857
skinparam ActorBackgroundColor #ECFDF5
skinparam ParticipantBorderColor #2563EB
skinparam ParticipantBackgroundColor #F8FAFC
skinparam SequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 85
skinparam ParticipantPadding 13
skinparam BoxPadding 8
